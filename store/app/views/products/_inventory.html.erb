<div class="inventory-box">
  <% if product.inventory_count.to_i.positive? %>
    <p class="in-stock">&#10003; <%= product.inventory_count %> in stock</p>
  <% else %>
    <p class="out-of-stock">Out of stock</p>
    <p style="font-size:0.875rem; color: var(--text-muted); margin-top:0.25rem;">Notify me when available</p>
    <%= form_with model: [product, Subscriber.new], class: "subscribe-form" do |form| %>
      <%= form.email_field :email, placeholder: "you@example.com", required: true %>
      <%= form.submit "Notify me" %>
    <% end %>
  <% end %>
</div>
